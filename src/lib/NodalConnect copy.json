  "components": {
    "schemas": {
      "UpdateExecutableDefinitionRequest": {
        "type": "object",
        "description": "Request used to update executables.",
        "properties": {
          "procName": {
            "type": "string",
            "description": "Stored Procedure Name",
            "example": "HFS_GET_TRIP_DETAIL",
            "maxLength": 128,
            "minLength": 0
          },
          "paramDefinition": {
            "type": "string",
            "default": [],
            "description": "JSON parameter definition for this executable",
            "example": [
              {
                "name": "IDLID",
                "mode": "IN",
                "type": "INTEGER",
                "required": true
              }
            ]
          },
          "active": {
            "type": "boolean",
            "default": false,
            "description": "Whether the executable should be active",
            "example": true
          },
          "description": {
            "type": "string",
            "description": "Description of executable function",
            "example": "Returns a list of active trips",
            "maxLength": 500,
            "minLength": 0
          },
          "executableType": {
            "type": "string",
            "description": "Type of Executable",
            "enum": [
              "STORED_PROCEDURE",
              "SQL_QUERY"
            ],
            "example": "STORED_PROCEDURE"
          },
          "sqlQueryText": {
            "type": "string",
            "description": "SQL Query Text to Execute",
            "example": "SELECT * FROM TLORDER WHERE BILL_TO_CODE = :BILL_TO_CODE LIMIT 10"
          },
          "dbConnectionId": {
            "type": "string",
            "description": "Database connection name or ID",
            "example": "TMWDEV"
          },
          "maxBatchSize": {
            "type": "integer",
            "format": "int32",
            "description": "Maximum size for batches, Leave empty to disable",
            "example": 100,
            "minimum": 1
          }
        }
      },
      "EntityModelExecutableDefinition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "procName": {
            "type": "string"
          },
          "paramDefinition": {
            "type": "string"
          },
          "active": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "executableType": {
            "type": "string"
          },
          "sqlQueryText": {
            "type": "string"
          },
          "dbConnectionId": {
            "type": "string"
          },
          "dbConnectionName": {
            "type": "string"
          },
          "maxBatchSize": {
            "type": "integer",
            "format": "int32"
          },
          "resultColumns": {
            "type": "string"
          },
          "_links": {
            "$ref": "#/components/schemas/Links"
          }
        }
      },
      "RequestInputs": {
        "type": "object",
        "description": "Input parameters as key-value pairs",
        "example": {
          "IDLID": 186211
        },
        "properties": {
          "empty": {
            "type": "boolean"
          }
        }
      },
      "ExecuteRequest": {
        "type": "object",
        "description": "Request to execute or validate a configured executable",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the executable to run",
            "example": "getTripDetails",
            "minLength": 1
          },
          "inputs": {

          }
        },
        "required": [
          "name"
        ]
      },
      "ParamDef": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "length": {
            "type": "integer",
            "format": "int32"
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "ValidationResult": {
        "type": "object",
        "description": "Result of validating an execution request",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Whether the validation passed",
            "example": true
          },
          "executableName": {
            "type": "string",
            "description": "Name of the executable being validated",
            "example": "getTripDetails"
          },
          "schema": {
            "type": "string",
            "description": "Database schema name",
            "example": "MYSCHEMA"
          },
          "procedure": {
            "type": "string",
            "description": "Stored procedure name",
            "example": "HFS_GET_TRIP_DETAIL"
          },
          "validatedInputs": {
            "type": "object",
            "additionalProperties": {

            },
            "description": "Validated and coerced input parameters"
          },
          "parameterDefinitions": {
            "type": "array",
            "description": "Parameter definitions for this executable",
            "items": {
              "$ref": "#/components/schemas/ParamDef"
            }
          },
          "message": {
            "type": "string",
            "description": "Validation result message",
