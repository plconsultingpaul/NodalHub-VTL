    "/executables/validate": {
      "post": {
        "tags": [
          "Validate"
        ],
        "summary": "Validate execution request",
        "description": "Validates parameters and configuration without executing. Send inputs as a JSON object for single validation, or as a JSON array for batch validation.",
        "operationId": "validateExecution",
        "requestBody": {
          "description": "Validation request with executable name and input parameters",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              },
              "examples": {
                "Single validation": {
                  "summary": "Validate a single set of parameters",
                  "description": "Single validation",
                  "value": {
                    "name": "getTripDetails",
                    "inputs": {
                      "IDLID": 12345
                    }
                  }
                },
                "Batch validation": {
                  "summary": "Validate multiple sets of parameters",
                  "description": "Batch validation",
                  "value": {
                    "name": "getTripDetails",
                    "inputs": [
                      {
                        "IDLID": 12345
                      },
                      {
                        "IDLID": 67890
                      }
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Validation completed",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ValidationResult"
                    },
                    {
                      "$ref": "#/components/schemas/BatchValidationResult"
                    }
                  ]
                },
                "examples": {
                  "Single validation response": {
                    "summary": "Response when inputs is a JSON object",
                    "description": "Single validation response",
                    "value": {
                      "valid": true,
                      "executableName": "getTripDetails",
                      "schema": "MYSCHEMA",
                      "procedure": "HFS_GET_TRIP_DETAIL",
                      "validatedInputs": {
                        "IDLID": 12345
                      },
                      "parameterDefinitions": [
                        {
                          "name": "IDLID",
                          "mode": "IN",
                          "type": "INTEGER",
                          "length": null,
                          "required": true
                        }
                      ],
                      "message": "All validations passed. Ready for execution."
                    }
                  },
                  "Batch validation response": {
                    "summary": "Response when inputs is a JSON array",
                    "description": "Batch validation response",
                    "value": {
                      "valid": true,
                      "executableName": "getTripDetails",
                      "totalItems": 2,
                      "validCount": 2,
                      "invalidCount": 0,
                      "results": [
                        {
                          "index": 0,
                          "valid": true,
                          "validatedInputs": {
                            "IDLID": 12345
                          },
                          "error": null
                        },
                        {
                          "index": 1,
                          "valid": true,
                          "validatedInputs": {
                            "IDLID": 67890
                          },
                          "error": null
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters or request format",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Executable not found or inactive",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          },
          {
            "apiKey": []
          }
        ]
      }
    },
    "/executables/run": {
      "post": {
        "tags": [
          "Execute"
        ],
        "summary": "Run executable",
        "description": "Executes a stored procedure or SQL query. Send inputs as a JSON object for single execution, or as a JSON array of objects for batch execution. The response schema differs accordingly.",
        "operationId": "run",
        "requestBody": {
          "description": "Execution request with executable name and input parameters",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              },
              "examples": {
                "Single execution": {
                  "summary": "Execute once with a single set of parameters",
                  "description": "Single execution",
                  "value": {
                    "name": "getTripDetails",
                    "inputs": {
                      "IDLID": 12345
                    }
                  }
                },
                "Batch execution": {
                  "summary": "Execute multiple times with an array of parameter sets",
                  "description": "Batch execution",
                  "value": {
                    "name": "getTripDetails",
                    "inputs": [
                      {
                        "IDLID": 12345
                      },
                      {
                        "IDLID": 67890
                      }
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Execution completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ExecutionResult"
                    },
                    {
                      "$ref": "#/components/schemas/BatchExecutionResult"
                    }
                  ]
                },
                "examples": {
                  "Single execution response": {
                    "summary": "Response when inputs is a JSON object",
                    "description": "Single execution response",
                    "value": {
                      "executableCode": "getTripDetails",
                      "outParams": {

                      },
                      "rows": [
                        {
                          "TRIP_ID": 12345,
                          "STATUS": "ACTIVE"
                        }
                      ]
                    }
                  },
                  "Batch execution response": {
                    "summary": "Response when inputs is a JSON array",
                    "description": "Batch execution response",
                    "value": {
                      "executableCode": "getTripDetails",
                      "totalRequests": 2,
                      "successCount": 2,
                      "failureCount": 0,
                      "results": [
                        {
                          "index": 0,
                          "success": true,
                          "result": {
                            "executableCode": "getTripDetails",
                            "outParams": {

                            },
                            "rows": [
                              {
                                "TRIP_ID": 12345,
                                "STATUS": "ACTIVE"
                              }
                            ]
                          },
                          "error": null
                        },
                        {
                          "index": 1,
                          "success": true,
                          "result": {
                            "executableCode": "getTripDetails",
                            "outParams": {

                            },
                            "rows": [
                              {
                                "TRIP_ID": 67890,
                                "STATUS": "COMPLETED"
                              }
                            ]
                          },
                          "error": null
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters or request format",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "API key does not have permission to execute this executable",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Executable not found or inactive",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          },
          {
            "apiKey": []
          }
        ]
      }
    },
