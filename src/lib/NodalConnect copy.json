{
  "openapi": "3.1.0",
  "info": {
    "title": "NodalConnect API",
    "description": "REST API Documentation for NodalConnect",
    "version": "1.1.06"
  },
  "servers": [
    {
      "url": "https://nodal.prioritylogisticsinc.com:8083/jdata",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "Execute",
      "description": "Run executables and check database connectivity"
    },
    {
      "name": "Manage",
      "description": "Manage executables from via REST endpoints, Requires ADMIN key"
    },
    {
      "name": "Validate",
      "description": "Validate executable requests before running them"
    }
  ],
  "paths": {
    "/executables/manage/{name}": {
